# Copy to .env.local and fill in.

# Anthropic API key for on-demand module generation (/api/generate).
# Without it the route runs in demo mode (re-skins the built-in module).
# Get one at https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional: force demo mode even when a key is present.
# METHOD_GENERATION_MOCK=1

# Optional: override the generation model (default: claude-opus-4-8).
# GENERATION_MODEL=claude-opus-4-8

# Supabase (profiles, session resume, saved-module library).
# Without these, everything persists to localStorage instead.
# Run supabase/schema.sql in the Supabase SQL editor first.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME
